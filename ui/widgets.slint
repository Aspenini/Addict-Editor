import { Theme } from "theme.slint";
import { LineEdit, SpinBox } from "std-widgets.slint";

export component Card inherits Rectangle {
    background: Theme.panel;
    border-radius: Theme.radius;
    border-width: 1px;
    border-color: Theme.border;
}

export component SectionTitle inherits Text {
    color: Theme.text;
    font-size: 16px;
    font-weight: 700;
}

export component Hint inherits Text {
    color: Theme.text-dim;
    font-size: 12px;
    wrap: word-wrap;
}

export component ActionButton inherits Rectangle {
    in property <string> text;
    in property <bool> danger: false;
    in property <bool> enabled: true;
    callback clicked();

    height: 34px;
    border-radius: Theme.radius;
    background: danger ? Theme.danger : Theme.accent;
    opacity: enabled ? (touch.pressed ? 0.78 : (touch.has-hover ? 0.88 : 1.0)) : 0.35;
    animate opacity { duration: 120ms; easing: ease-out; }

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        alignment: center;
        Text {
            text: root.text;
            color: Theme.accent-text;
            vertical-alignment: center;
            horizontal-alignment: center;
            font-size: 13px;
            font-weight: 600;
            wrap: no-wrap;
            overflow: elide;
        }
    }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
}

export component GhostButton inherits Rectangle {
    in property <string> text;
    in property <string> icon;
    in property <bool> collapsed: false;
    in property <bool> active: false;
    callback clicked();

    height: 38px;
    border-radius: Theme.radius;
    background: active ? Theme.accent : (touch.has-hover ? Theme.panel-alt : transparent);
    animate background { duration: 140ms; easing: ease-out; }

    // Accent marker on the active item.
    Rectangle {
        x: 0;
        width: 3px;
        height: active ? parent.height - 14px : 0px;
        y: parent.height / 2 - self.height / 2;
        border-radius: 2px;
        background: Theme.accent-text;
        opacity: active ? 0.9 : 0;
        animate height, opacity { duration: 160ms; easing: ease-out; }
    }

    HorizontalLayout {
        padding-left: root.collapsed ? 0px : 12px;
        padding-right: root.collapsed ? 0px : 12px;
        spacing: root.collapsed ? 0px : 10px;
        alignment: root.collapsed ? center : start;
        Text {
            text: root.icon;
            color: active ? Theme.accent-text : Theme.text;
            vertical-alignment: center;
            horizontal-alignment: center;
            width: 20px;
            font-size: 15px;
        }
        if !root.collapsed: Text {
            text: root.text;
            color: active ? Theme.accent-text : Theme.text;
            vertical-alignment: center;
            font-size: 13px;
            font-weight: active ? 700 : 500;
            overflow: elide;
        }
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

// A compact icon-less round button used for the sidebar collapse toggle.
export component IconButton inherits Rectangle {
    in property <string> glyph;
    callback clicked();
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: touch.has-hover ? Theme.panel-alt : transparent;
    animate background { duration: 120ms; easing: ease-out; }
    Text {
        text: root.glyph;
        color: Theme.text;
        font-size: 18px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

// A labelled SpinBox row with a max limit.
export component NumberField inherits VerticalLayout {
    in property <string> label;
    in property <int> minimum: 0;
    in property <int> maximum: 999999999;
    in-out property <int> value;
    callback edited();
    spacing: 4px;
    Text {
        text: root.label;
        color: Theme.text-dim;
        font-size: 12px;
    }
    spin := SpinBox {
        minimum: root.minimum;
        maximum: root.maximum;
        value <=> root.value;
        edited => { root.edited(); }
    }
}

export component Field inherits VerticalLayout {
    in property <string> label;
    in-out property <string> text <=> input.text;
    in property <string> placeholder;
    callback edited();
    spacing: 4px;

    Text {
        text: root.label;
        color: Theme.text-dim;
        font-size: 12px;
    }

    input := LineEdit {
        placeholder-text: root.placeholder;
        edited => { root.edited(); }
    }
}
