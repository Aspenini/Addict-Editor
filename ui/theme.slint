// Global theme/palette for Addict Editor.
// mode: 0 = Dark, 1 = Light, 2 = Dracula, 3 = Solarized
export global Theme {
    in-out property <int> mode: 0;

    out property <brush> bg:
        mode == 1 ? #f3f3f5 :
        mode == 2 ? #282a36 :
        mode == 3 ? #002b36 :
        #1a1a1e;

    out property <brush> panel:
        mode == 1 ? #ffffff :
        mode == 2 ? #343746 :
        mode == 3 ? #073642 :
        #242429;

    out property <brush> panel-alt:
        mode == 1 ? #e9e9ee :
        mode == 2 ? #21222c :
        mode == 3 ? #00212b :
        #2e2e35;

    out property <brush> accent:
        mode == 1 ? #2d6cdf :
        mode == 2 ? #bd93f9 :
        mode == 3 ? #268bd2 :
        #6c8cff;

    out property <brush> accent-text: #ffffff;

    out property <brush> text:
        mode == 1 ? #1a1a1e :
        mode == 2 ? #f8f8f2 :
        mode == 3 ? #93a1a1 :
        #e8e8ee;

    out property <brush> text-dim:
        mode == 1 ? #5a5a66 :
        mode == 2 ? #9aa0b5 :
        mode == 3 ? #586e75 :
        #9a9aa5;

    out property <brush> border:
        mode == 1 ? #d0d0d8 :
        mode == 2 ? #44475a :
        mode == 3 ? #0a3d49 :
        #3a3a42;

    out property <brush> danger: #e0584f;
    out property <brush> success: #46b06a;

    out property <length> radius: 8px;
    out property <length> gap: 12px;
}
